# Backend Configuration
PORT=3000
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Contract Addresses
CHECKOUT_CONTRACT_ADDRESS=0xc200b8d056bc579c62f53d6832e50f066e98f0af
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3

# Admin Wallet (pays gas for relayed transactions)
# IMPORTANT: Never commit this to git, only use in .env locally
# For production, use a secure key management system
ADMIN_PRIVATE_KEY=0x_YOUR_ADMIN_WALLET_PRIVATE_KEY_HERE

# Optional: Database/Order Storage
DATABASE_URL=your_database_url_here
