{
  "version": 2,
  "env": [
    "ADMIN_PRIVATE_KEY",
    "RPC_URL",
    "CHECKOUT_CONTRACT_ADDRESS"
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
