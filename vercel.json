{
  "version": 2,
  "env": {
    "ADMIN_PRIVATE_KEY": "@admin_private_key",
    "RPC_URL": "@rpc_url",
    "CHECKOUT_CONTRACT_ADDRESS": "@checkout_contract_address"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
